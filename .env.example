# ========================================
# Конфигурация для snbld resvap
# ========================================
# Скопируй этот файл в .env и заполни реальными значениями
# .env находится в .gitignore и НЕ коммитится!

# ----------------------------------------
# Selectel S3 (для загрузки обновлений)
# ----------------------------------------
SELECTEL_ACCESS_KEY=your_access_key_here
SELECTEL_SECRET_KEY=your_secret_key_here

# ----------------------------------------
# Telegram Bot (для уведомлений)
# ----------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ----------------------------------------
# Beget Server (для загрузки файлов)
# ----------------------------------------
BEGET_SSH_HOST=snbld.ru
BEGET_SSH_USER=your_username_here
BEGET_SSH_PASSWORD=your_password_here
BEGET_EXE_PATH=/home/s/snbld/snbld.beget.tech/myapp/downloads/snbld_base.exe
